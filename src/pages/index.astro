---
import { API_KEY } from "astro:env/server";
import { StatusPage } from "../components/status-page";
import { monitorsSchema, summaryPayload } from "../utils/models.js";
import { overallStatus, toMonitorStatus } from "../utils/status";
import "../styles/global.css";

const headers = {
  "x-openstatus-key": API_KEY,
  "Cache-Control": "max-age=600", // Cache for 10 minutes
};

const response = await fetch("https://api.openstatus.dev/v1/monitor", {
  headers,
});

// TODO: error handling! if response is not ok (e.g. wrong API_KEY)

const data = await response.json();
const r = monitorsSchema.parse(data);

// our monitors id
const monitorIds = [10022];
const selected = r.filter((m) => monitorIds.find((id) => m.id === id));

const monitors = await Promise.all(
  selected.map(async (monitor) => {
    const res = await fetch(
      `https://api.openstatus.dev/v1/monitor/${monitor.id}/summary`,
      { headers },
    );
    const summary = summaryPayload.parse(await res.json());
    return toMonitorStatus(monitor, summary.data.reverse());
  }),
);

const status = overallStatus(monitors);
---

<html lang="en">
  <head>
    <meta charset="utf-8" />
    <link rel="icon" type="image/svg+xml" href="/favicon.svg" />
    <meta name="viewport" content="width=device-width" />
    <meta name="generator" content={Astro.generator} />
    <meta
      name="description"
      content="Fork your own astro status page for your openstatus workspace."
    />
    <title>Status Page</title>
  </head>
  <body>
    <StatusPage monitors={monitors} status={status} client:load />
  </body>
</html>
