---
import { ConnectError } from "@connectrpc/connect";
import { API_KEY, STATUS_PAGE_ID } from "astro:env/server";
import { StatusPage } from "../components/status-page";
import { loadStatusPage } from "../utils/openstatus";
import "../styles/global.css";

let view = null;
try {
  view = await loadStatusPage({ apiKey: API_KEY, pageId: STATUS_PAGE_ID });
} catch (error) {
  if (!(error instanceof ConnectError)) throw error;
  console.error(`Failed to load status page: ${error.code} ${error.message}`);
}
---

<html lang="en">
  <head>
    <meta charset="utf-8" />
    <link rel="icon" type="image/svg+xml" href="/favicon.svg" />
    <meta name="viewport" content="width=device-width" />
    <meta name="generator" content={Astro.generator} />
    <meta
      name="description"
      content="Fork your own astro status page for your openstatus workspace."
    />
    <title>{view?.title ?? "Status Page"}</title>
  </head>
  <body>
    {
      view ? (
        <StatusPage view={view} client:load />
      ) : (
        <main class="mx-auto max-w-2xl px-3 py-8">
          <p class="text-muted-foreground">
            Status is temporarily unavailable. Please try again later.
          </p>
        </main>
      )
    }
  </body>
</html>
