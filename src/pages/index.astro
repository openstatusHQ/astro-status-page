---
import "../styles/global.css";
import { StatusPage } from "../components/status-page";
import {
  fetchMonitors,
  fetchMonitorDailySummary,
  fetchStatusReports,
  fetchMaintenances,
  dailyStatsToBarData,
  computeUptime,
  computeOverallStatus,
  transformStatusReports,
  transformMaintenances,
} from "../lib/api";
import type { StatusType } from "../components/blocks/status.types";

const API_KEY = import.meta.env.API_KEY;
// For Cloudflare bindings, use: import { env } from 'cloudflare:workers';

const monitorIds = ["9172"];

// Fetch all data in parallel
const [allMonitors, v2StatusReports, v2Maintenances] = await Promise.all([
  fetchMonitors(API_KEY),
  fetchStatusReports(API_KEY),
  fetchMaintenances(API_KEY),
]);

// Filter to our monitors
const monitors = allMonitors.filter((m) => monitorIds.includes(m.id));

// Fetch daily summaries for each monitor (REST v1 — v2 only has aggregated data)
const summaries = await Promise.all(
  monitors.map((m) => fetchMonitorDailySummary(API_KEY, m.id)),
);

// Build monitor data for the component
const monitorData = monitors.map((monitor, i) => {
  const stats = summaries[i];
  const barData = dailyStatsToBarData(stats);
  const uptime = computeUptime(stats);
  const status = computeOverallStatus(stats);
  const variant: Exclude<StatusType, "empty"> =
    status === "empty" ? "success" : status;

  return {
    id: Number(monitor.id),
    name: monitor.name || monitor.url,
    description: ("description" in monitor ? monitor.description : null) as string | null,
    variant,
    uptime: `${uptime.toFixed(2)}%`,
    barData,
  };
});

// Compute overall status from all monitors
const allStats = summaries.flat();
const overallStatus = computeOverallStatus(allStats);

// Transform v2 responses to UI component types
const statusReports = transformStatusReports(v2StatusReports);
const maintenances = transformMaintenances(v2Maintenances);
---

<html lang="en">
  <head>
    <meta charset="utf-8" />
    <link rel="icon" type="image/svg+xml" href="/favicon.svg" />
    <meta name="viewport" content="width=device-width" />
    <meta name="generator" content={Astro.generator} />
    <meta
      name="description"
      content="Fork your own astro status page for your openstatus workspace."
    />
    <title>Status Page</title>
  </head>
  <body class="min-h-screen bg-background text-foreground">
    <main class="mx-auto max-w-xl px-4 py-8">
      <StatusPage
        client:load
        overallStatus={overallStatus}
        monitors={monitorData}
        statusReports={statusReports}
        maintenances={maintenances}
      />
      <footer class="mt-8">
        <p class="text-muted-foreground text-center text-sm">
          powered by{" "}
          <a
            href="https://www.openstatus.dev"
            target="_blank"
            rel="noreferrer"
            class="text-foreground underline underline-offset-4 hover:no-underline"
          >
            openstatus.dev
          </a>
        </p>
      </footer>
    </main>
  </body>
</html>
